# Python backend (backend_api / backend_workers)
USE_MOCK=true
OPENAI_API_KEY=your_openai_key_here
DAYTONA_API_KEY=your_daytona_key_here
DAYTONA_API_URL=https://app.daytona.io/api

# TypeScript frontend server (Railway / Netlify / Cloudflare)
# These are read server-side via process.env or Cloudflare env bindings.
# DAYTONA_API_KEY=your_daytona_key_here
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_TARGET=          # optional: leave blank for default region
